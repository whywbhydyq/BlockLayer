{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "moduleResolution": "node",
    "skipLibCheck": true,
    "outDir": ".audit-dist",
    "rootDir": ".",
    "noEmit": false,
    "jsx": "react-jsx"
  },
  "include": [
    "src/lib/geometry/**/*.ts",
    "src/lib/export/**/*.ts",
    "src/lib/render/**/*.ts",
    "tests/**/*.ts"
  ]
}
